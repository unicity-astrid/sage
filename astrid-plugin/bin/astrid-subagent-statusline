#!/usr/bin/env sh
# Astrid subagent status line — tags each Task-tool sub-agent row in the agent
# panel with the Astrid governance dot, so sub-agents read as governed too.
#
# Claude Code runs this ONCE per refresh tick with ALL visible subagent rows on
# stdin: { columns, tasks: [{ id, name, type, status, tokenCount, cwd, ... }] }.
# We emit one JSON line per row we override: {"id": "<task id>", "content": ...}.
#
# Governance dot (green ● governed / yellow ◐ broker-missing / dim ○ down) is the
# CACHED daemon round-trip shared with the main HUD (~/.astrid/run/.hud-health,
# 15s TTL), so this stays cheap. Requires jq; without it we emit nothing and
# Claude Code keeps its default rows.
set -eu

input="$(cat 2>/dev/null || true)"
command -v jq >/dev/null 2>&1 || exit 0

ASTRID="$(command -v astrid 2>/dev/null || true)"
[ -n "$ASTRID" ] || ASTRID="$HOME/.astrid/bin/astrid"
ASTRID_HOME_DIR="${ASTRID_HOME:-$HOME/.astrid}"
SOCK="$ASTRID_HOME_DIR/run/system.sock"

ESC=$(printf '\033')
C_RESET="${ESC}[0m"; C_GN="${ESC}[32m"; C_YE="${ESC}[33m"; C_GY="${ESC}[90m"; C_DIM="${ESC}[2m"

# Cached governance health (mirrors astrid-hud.sh / the plugin HUD).
HEALTH_CACHE="$ASTRID_HOME_DIR/run/.hud-health"
HEALTH_TTL=15
NOW="$(date +%s 2>/dev/null || echo 0)"
GATE=""
if [ -r "$HEALTH_CACHE" ]; then
  cached="$(cat "$HEALTH_CACHE" 2>/dev/null || true)"
  c_ts="${cached%% *}"; c_state="${cached#* }"
  if [ -n "$c_ts" ] && [ "$NOW" -gt 0 ] && [ "$c_ts" -eq "$c_ts" ] 2>/dev/null; then
    age=$(( NOW - c_ts ))
    [ "$age" -ge 0 ] && [ "$age" -lt "$HEALTH_TTL" ] && GATE="$c_state"
  fi
fi
if [ -z "$GATE" ]; then
  if [ ! -S "$SOCK" ]; then
    GATE="down"
  elif [ -x "$ASTRID" ]; then
    st="$( { if command -v timeout >/dev/null 2>&1; then timeout 2 "$ASTRID" status; \
             else "$ASTRID" status; fi; } 2>/dev/null || true )"
    if ! printf '%s' "$st" | grep -q '(PID'; then GATE="down"
    elif printf '%s' "$st" | sed -n 's/^[[:space:]]*-[[:space:]]*//p' | grep -qiE 'sage-mcp'; then GATE="up"
    else GATE="degraded"; fi
  else
    GATE="down"
  fi
  printf '%s %s\n' "$NOW" "$GATE" > "$HEALTH_CACHE" 2>/dev/null || true
fi
case "$GATE" in
  up)       DOT="${C_GN}●${C_RESET}" ;;
  degraded) DOT="${C_YE}◐${C_RESET}" ;;
  *)        DOT="${C_GY}○${C_RESET}" ;;
esac

# One override row per task: "<dot> <name> · <status> · <N> tok".
printf '%s' "$input" | jq -c \
  --arg dot "$DOT" --arg dim "$C_DIM" --arg rst "$C_RESET" '
  .tasks[]? | {
    id: .id,
    content: (
      $dot + " " + ((.name // .type // "subagent"))
      + (if (.status // "") != "" then " " + $dim + "· " + .status + $rst else "" end)
      + (if .tokenCount then " " + $dim + "· " + (.tokenCount|tostring) + " tok" + $rst else "" end)
    )
  }'

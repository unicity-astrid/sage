#!/usr/bin/env sh
# Ensure an Astrid daemon is up, then become the MCP stdio server for this
# Claude Code session.
#
# Bundled with the Astrid Claude Code plugin so installing the plugin needs
# no separate `astrid start` — the daemon comes up the first time Claude
# Code launches the MCP server, and tears itself down when the editor exits.
# A plugin cannot spawn a long-lived host daemon directly; this wrapper
# closes that gap from inside the plugin.
#
# DAEMON LIFECYCLE: we boot the daemon in EPHEMERAL mode (`astrid-daemon
# --ephemeral`), which auto-shuts-down ~30s after its last client
# disconnects. This session's `mcp serve` uplink is that client, so the
# daemon lives exactly as long as the editor (plus the grace window) and
# self-cleans afterwards — no orphaned background process. We deliberately
# do NOT use `astrid start`, which forces PERSISTENT mode (stays up until
# `astrid stop`). If a daemon is already running (persistent or ephemeral,
# e.g. a second concurrent Claude session, or one you started by hand) we
# reuse it untouched; the connection counter ref-counts the shared daemon.
#
# stdout DISCIPLINE: the MCP transport owns stdout — only the JSON-RPC
# stream produced by `astrid mcp serve` may go there. Everything this
# wrapper emits goes to stderr, and the daemon-start output is silenced, so
# a stray line can never corrupt the protocol framing.
set -eu

log() { printf 'astrid-up: %s\n' "$*" >&2; }

# Resolve the astrid binary: PATH first, then the default install location.
ASTRID="$(command -v astrid 2>/dev/null || true)"
[ -n "$ASTRID" ] || ASTRID="$HOME/.astrid/bin/astrid"
if [ ! -x "$ASTRID" ]; then
  log "cannot find the 'astrid' binary (not on PATH, not at $HOME/.astrid/bin/astrid). Install Astrid first."
  exit 127
fi

# The readiness sentinel the daemon writes once every capsule is loaded and
# the accept loop is live. Mirrors astrid-core::dirs (run/system.ready under
# ASTRID_HOME, default ~/.astrid).
ASTRID_HOME_DIR="${ASTRID_HOME:-$HOME/.astrid}"
READY="$ASTRID_HOME_DIR/run/system.ready"

# Liveness probe. `astrid status` exits 0 whether the daemon is up OR down
# (it just prints a human line), so the exit code is useless here — we match
# the live-status line instead, which is emitted ONLY after a successful
# round-trip to a running daemon. A false negative is self-healing: the
# redundant boot below fails to bind the in-use socket and exits harmlessly,
# and `mcp serve` connects to the daemon that is already up.
daemon_live() { "$ASTRID" status 2>/dev/null | grep -q '(PID'; }

if ! daemon_live; then
  # No reachable daemon — boot one in EPHEMERAL mode so it self-cleans.
  ASTRID_BIN_DIR="$(dirname "$ASTRID")"
  DAEMON="$ASTRID_BIN_DIR/astrid-daemon"
  [ -x "$DAEMON" ] || DAEMON="$(command -v astrid-daemon 2>/dev/null || true)"
  if [ -z "$DAEMON" ] || [ ! -x "$DAEMON" ]; then
    log "no daemon running and cannot find 'astrid-daemon' to boot one (looked next to $ASTRID and on PATH)."
    log "start one yourself with: astrid start"
    exit 127
  fi

  log "no daemon running — booting one (ephemeral, self-cleaning)..."
  # Detach via a subshell that exits immediately, so the daemon reparents to
  # init right away and outlives this wrapper (and the `mcp serve` it execs
  # into) — exactly how the CLI's own spawn_daemon detaches it. No controlling
  # stdio; both streams silenced so nothing can reach the MCP stdout stream.
  ( "$DAEMON" --ephemeral </dev/null >/dev/null 2>&1 & )

  # Wait for readiness (~10s budget, matching the CLI's own boot poll). The
  # sleep is guarded: a strict/busybox `sleep` that rejects fractional
  # seconds must not abort the script under `set -e`.
  i=0
  while [ "$i" -lt 200 ]; do
    if [ -e "$READY" ] && daemon_live; then
      break
    fi
    sleep 0.05 2>/dev/null || sleep 1
    i=$((i + 1))
  done

  if ! daemon_live; then
    log "daemon did not become ready within 10s. Check logs under $ASTRID_HOME_DIR/log."
    exit 1
  fi
fi

# Resolve the principal this session will act as. Claude Code expands the
# `${user_config.principal}` arg from .mcp.json: a configured value arrives as
# `--principal <name>`; a blank one (operator cleared it) collapses to a lone
# `--principal` with no value.
PRINCIPAL=""
[ "${1:-}" = "--principal" ] && PRINCIPAL="${2:-}"

# Blank principal: drop the dangling flag so `astrid mcp serve` resolves the
# active CLI principal itself (context::resolve_agent → active agent context,
# else `default`). Claude Code expands a blank `${user_config.principal}` and
# DROPS the empty value, so the server is invoked as `astrid-up --principal`
# (one arg), not `--principal ""` (two). A blind `shift 2` then over-shifts
# and aborts under `set -eu`, killing the MCP server — so drop the flag, and
# the empty value only if it was actually passed.
if [ "${1:-}" = "--principal" ] && [ -z "$PRINCIPAL" ]; then
  shift
  [ "$#" -gt 0 ] && shift
fi

# Publish the resolved session principal for the read-only display surfaces
# (SessionStart doctor, HUD status line, /astrid:whoami) so they report the
# identity this session ACTS AS — not the operator's active CLI context, which
# stays `default`/admin and is intentionally decoupled. Co-located with the
# run-dir sentinels those scripts already resolve (a live daemon owns the dir).
# Best-effort: a write failure only degrades the displays to their CLI-context
# fallback, never the session itself.
SESSION_PRINCIPAL_FILE="$ASTRID_HOME_DIR/run/session.principal"
if [ -n "$PRINCIPAL" ]; then
  printf '%s\n' "$PRINCIPAL" > "$SESSION_PRINCIPAL_FILE" 2>/dev/null \
    || log "note: could not publish session principal to $SESSION_PRINCIPAL_FILE; HUD/doctor fall back to the CLI context."
else
  # Blank → `mcp serve` resolves the active context itself; clear any stale
  # value so the displays fall back to that same context, not a past session.
  # A missing file is the desired end state, so a failed remove is not a fault.
  rm -f "$SESSION_PRINCIPAL_FILE" 2>/dev/null || true
fi

# Provision the session principal as a SCOPED agent before serving as it, placed
# in the `claude` FAMILY group rather than the generic built-in `agent` tier.
# The `claude` group is a custom, operator-manageable group carrying the same
# self-scoped baseline the built-in `agent` group grants (`self:*`,
# `delegate:self:*`): self-service over the principal's OWN session/quota/KV plus
# recursive delegation, and NONE of the admin-meta surface the `default`
# principal holds via the `admin` group (`*`). So the governed Claude session can
# drive its own tools but cannot administer the OS it runs on — no system-wide
# capsule:install, no agent:* / group:* / caps:grant, no quota:set on other
# principals, no system:shutdown, no audit:read_all across principals. Claude
# runs as a least-authority agent, not as admin.
#
# Why a named `claude` group instead of the built-in `agent`: it is the Claude
# product FAMILY identity. Per-product principals (claude-code here; claude-chat,
# cowork later) share this one baseline and diverge via per-principal
# grants/revokes (precedence: revokes > grants > group). An operator can re-tune
# the whole family's authority in one place — `astrid group modify claude
# --add-caps ...` propagates live to every member on its next check — while the
# built-in `agent` tier stays the generic fallback for non-Claude agents.
#
#   group create claude --caps self:*,delegate:self:*   the family baseline
#   agent create <p> --group claude --yes               scoped principal in it
#   --yes                   non-interactive (no TTY in a plugin/MCP context)
#   --inherit-from default  copy the operator's env/KV/secrets so tool execution
#                           behaves identically, minus that authority. Landed
#                           after astrid 0.8.0; on an older CLI it is rejected and
#                           we fall back to the plain scoped create. The scoping
#                           (group `claude`) is identical either way — only the
#                           env/secret carry-over is version-gated.
#
# Idempotent + non-fatal, but NOT silent: a second run hits "already exists"
# (benign — expected on every launch after the first) and stays quiet; any OTHER
# failure (daemon unreachable, capability denied, …) is surfaced as a WARNING on
# stderr so a broken provision is visible, not swallowed. Still non-fatal:
# serving the session matters more than wedging on a provisioning hiccup, and an
# unprovisioned principal falls back to an empty profile (zero caps) — MORE
# restrictive, so the degradation fails secure on the cap axis. We never
# auto-create `default` — the reserved bootstrap admin identity (the kernel
# refuses to re-create it regardless) — so opting a session into it is a
# deliberate operator choice, not something this wrapper does.
#
# NOTE (hard floor): per-connection principal auth has LANDED. `agent create`
# mints a per-principal ed25519 keypair (keys/<p>.key in system custody + a
# registered public key on the profile) and `astrid mcp serve` signs the socket
# handshake challenge with it, so the daemon CRYPTOGRAPHICALLY binds this
# connection to PRINCIPAL. A connection that cannot sign is stamped the
# no-capability `anonymous` (fail-closed: a bad signature fails the handshake,
# never falls back to unauthenticated). The scoping below is therefore an
# enforced boundary, not just an honest default.
if [ -n "$PRINCIPAL" ] && [ "$PRINCIPAL" != "default" ]; then
  # Ensure the `claude` family group exists before placing the principal in it.
  # CREATE-IF-ABSENT, never reconcile: we only `group create` when `group show`
  # reports it missing, so an operator who later retunes the group
  # (`astrid group modify claude --add-caps/--remove-caps`) keeps that change —
  # a subsequent launch sees the group present and skips the create entirely.
  # Belt & suspenders: `group create` is create-only (the kernel rejects a
  # redundant create as "declares ... more than once"), so it can NEVER overwrite
  # existing caps even if the `group show` guard is lost to a race. Likewise the
  # `agent create` below no-ops on an existing principal, so an operator's group
  # reassignment of the principal also survives.
  if ! "$ASTRID" group show claude >/dev/null 2>&1; then
    if group_out="$("$ASTRID" group create claude \
        --caps "self:*,delegate:self:*" \
        --description "Claude product family — self-scoped baseline" 2>&1)"; then
      log "created the 'claude' capability group (self-scoped baseline)."
    else
      case "$group_out" in
        # Exists already, or a concurrent launch won the create between our
        # `group show` guard and here — both benign. The kernel reports a
        # redundant create as "declares ... more than once", not "exists".
        *"already exists"*|*"more than once"*) : ;;
        *)
          log "WARNING: could not create the 'claude' group:"
          log "  ${group_out:-<no output>}"
          log "  '$PRINCIPAL' may fall back to an unscoped profile." ;;
      esac
    fi
  fi

  log "ensuring scoped agent principal '$PRINCIPAL' exists (group 'claude')..."
  # Enriched form first (carries env/secrets, post-0.8.0); fall back to the plain
  # scoped create. Both place the principal in the `claude` group. Capture output
  # so a real failure can be reported.
  if create_out="$("$ASTRID" agent create "$PRINCIPAL" --group claude --inherit-from default --yes 2>&1)" \
     || create_out="$("$ASTRID" agent create "$PRINCIPAL" --group claude --yes 2>&1)"; then
    log "scoped principal '$PRINCIPAL' ready."
  else
    case "$create_out" in
      *"already exists"*)
        # The principal was provisioned earlier — the EXPECTED steady state. But
        # a principal created BEFORE per-connection auth landed is keyless, and
        # the shaped create above can NEVER heal it: any profile-shaping input
        # (`--group`, `--inherit-from`) makes `agent create` keep the hard
        # "already exists" error instead of backfilling. The kernel backfills a
        # missing keypair ONLY on a BARE re-create (no shaping inputs), so make
        # that bare call now. Idempotent + security-positive: a keyless upgrader
        # gains its keypair (moving from a `anonymous`-stamped connection to its
        # own scoped identity); an already-keyed principal just re-reports
        # "already exists" (benign — the steady state on every later launch).
        if heal_out="$("$ASTRID" agent create "$PRINCIPAL" --yes 2>&1)"; then
          log "backfilled the missing keypair for existing principal '$PRINCIPAL'."
        else
          case "$heal_out" in
            *"already exists"*) : ;; # already keyed — nothing to heal
            *)
              log "WARNING: keypair backfill for '$PRINCIPAL' did not complete:"
              log "  ${heal_out:-<no output>}"
              log "  the session may be stamped 'anonymous' until '$PRINCIPAL' has a keypair." ;;
          esac
        fi
        ;;
      *)
        log "WARNING: failed to provision scoped principal '$PRINCIPAL':"
        log "  ${create_out:-<no output>}"
        log "  serving anyway; the session may fall back to an unscoped profile." ;;
    esac
  fi
fi

exec "$ASTRID" mcp serve "$@"

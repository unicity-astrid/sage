#!/usr/bin/env sh
# astrid-install — install the Astrid runtime (astrid, astrid-daemon,
# astrid-build) for the Astrid Claude Code plugin, so Astrid need not be a
# manual prerequisite. After this succeeds, bin/astrid-up finds the binaries
# and the plugin works on the next session.
#
# CONSENT MODEL — read this before wondering why the MCP server doesn't just
# install on boot. bin/astrid-up IS the MCP stdio server: it has no controlling
# terminal and its stdout is the JSON-RPC transport, so it can neither prompt
# for confirmation nor print install chatter without corrupting the protocol.
# Installing software silently at boot would also be presumptuous. So the install
# lives HERE, as an explicit, idempotent command you (or Claude, on your say-so,
# or the SessionStart doctor's prompt) run deliberately. astrid-up and
# astrid-doctor only POINT at this script; they never run it for you.
#
# Install method, strongest provenance first:
#   1. Homebrew  — `brew install unicity-astrid/tap/astrid` (formula pins a
#      per-asset sha256; the strongest integrity guarantee available).
#   2. Prebuilt release tarball from GitHub, into ~/.astrid/bin. Fetched over
#      HTTPS (TLS-trusted) and checksum-verified IF the release publishes a
#      sibling `.sha256`. NOTE: Astrid releases are not code-signed yet, so the
#      binary path is trust-on-first-use over TLS — prefer Homebrew when present.
#   3. cargo build from source — only when no prebuilt binary matches your
#      platform (exotic arch/OS). Slow; best-effort, with manual steps on failure.
#
# Idempotent: a working `astrid` already on PATH or at ~/.astrid/bin is left
# untouched unless you pass --force.
#
# Env overrides:
#   ASTRID_HOME      install root for the binary path (default ~/.astrid)
#   ASTRID_VERSION   pin a release version for the binary path (default: latest)
set -eu

REPO="unicity-astrid/astrid"
TAP="unicity-astrid/tap"
ASTRID_HOME_DIR="${ASTRID_HOME:-$HOME/.astrid}"
BIN_DIR="$ASTRID_HOME_DIR/bin"
FORCE=0

log()  { printf 'astrid-install: %s\n' "$*" >&2; }
die()  { log "ERROR: $*"; exit 1; }

usage() {
  cat >&2 <<'USAGE'
astrid-install — install the Astrid runtime for the Claude Code plugin.

Usage: astrid-install [--force]

  --force   reinstall even if an `astrid` binary is already present.

Tries Homebrew first, then a prebuilt GitHub release binary, then a source
build. Honors ASTRID_HOME (install root) and ASTRID_VERSION (pin a release).
USAGE
}

while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) log "ignoring unrecognized argument: $1"; shift ;;
  esac
done

# --- Idempotency -----------------------------------------------------------
# Resolve an existing install the same way bin/astrid-up does: PATH first, then
# the plugin's default install location.
EXISTING="$(command -v astrid 2>/dev/null || true)"
[ -n "$EXISTING" ] || { [ -x "$BIN_DIR/astrid" ] && EXISTING="$BIN_DIR/astrid"; }
if [ -n "$EXISTING" ] && [ "$FORCE" -ne 1 ]; then
  log "astrid is already installed at $EXISTING ($("$EXISTING" --version 2>/dev/null || echo 'version unknown'))."
  log "Nothing to do. Re-run with --force to reinstall."
  exit 0
fi

# --- 1. Homebrew (preferred: pinned checksums) -----------------------------
if command -v brew >/dev/null 2>&1; then
  log "Homebrew detected — installing astrid via $TAP (formula pins per-asset checksums; preferred path)."
  # Fully-qualified name auto-taps; route brew's stdout to stderr so this
  # script's own stdout stays clean. Do NOT infer success from brew's exit
  # through a pipe — verify independently below (a piped exit masks the real one).
  brew install "$TAP/astrid" >&2 || log "brew reported a non-zero exit; verifying before falling back."
  if astrid_path="$(command -v astrid 2>/dev/null)"; then
    log "Installed via Homebrew at $astrid_path."
    "$astrid_path" --version >&2 2>/dev/null || true
    log "Done. Start a new Claude Code session (or run 'astrid start') to bring up the daemon."
    exit 0
  fi
  log "Homebrew did not place 'astrid' on PATH — falling back to the prebuilt binary."
fi

# --- 2. Prebuilt release binary --------------------------------------------
# Map the host to a release target triple. The release publishes exactly these
# four (see the Homebrew formula); anything else falls through to the source build.
OS="$(uname -s 2>/dev/null || echo unknown)"
ARCH="$(uname -m 2>/dev/null || echo unknown)"
TRIPLE=""
case "$OS" in
  Darwin)
    case "$ARCH" in
      arm64|aarch64) TRIPLE="aarch64-apple-darwin" ;;
      x86_64)        TRIPLE="x86_64-apple-darwin" ;;
    esac ;;
  Linux)
    case "$ARCH" in
      aarch64|arm64) TRIPLE="aarch64-unknown-linux-gnu" ;;
      x86_64)        TRIPLE="x86_64-unknown-linux-gnu" ;;
    esac ;;
esac

# sha256 helper that works on both Linux (sha256sum) and macOS (shasum -a 256).
sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}';
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}';
  else echo ""; fi
}

if [ -n "$TRIPLE" ]; then
  command -v curl >/dev/null 2>&1 || die "curl is required for the prebuilt-binary install (not found). Install curl, or use Homebrew."
  command -v tar  >/dev/null 2>&1 || die "tar is required for the prebuilt-binary install (not found)."

  # Resolve the version: an explicit pin, else the latest release tag.
  VERSION="${ASTRID_VERSION:-}"
  if [ -z "$VERSION" ]; then
    log "Resolving the latest Astrid release..."
    TAG="$(curl -fsSL "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null \
            | grep '"tag_name"' | head -n1 | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"//; s/".*//')"
    [ -n "$TAG" ] || die "could not resolve the latest release (GitHub API unreachable or rate-limited). Retry, set ASTRID_VERSION=X.Y.Z, or use Homebrew."
    VERSION="${TAG#v}"
  fi
  TAG="v$VERSION"
  ASSET="astrid-$VERSION-$TRIPLE.tar.gz"
  URL="https://github.com/$REPO/releases/download/$TAG/$ASSET"

  TMP="$(mktemp -d 2>/dev/null)" || die "could not create a temp directory."
  # Clean up the temp dir on any exit.
  trap 'rm -rf "$TMP"' EXIT INT TERM

  log "Downloading $ASSET ($TAG) for $OS/$ARCH..."
  curl -fsSL "$URL" -o "$TMP/$ASSET" || die "download failed: $URL"

  # Integrity: verify against a sibling .sha256 if the release publishes one;
  # otherwise proceed on TLS trust only and say so (no signing exists yet).
  EXPECTED="$(curl -fsSL "$URL.sha256" 2>/dev/null | awk '{print $1}' | head -n1 || true)"
  if [ -n "$EXPECTED" ]; then
    ACTUAL="$(sha256_of "$TMP/$ASSET")"
    if [ -z "$ACTUAL" ]; then
      log "WARNING: no sha256 tool available to verify the download; proceeding on TLS trust."
    elif [ "$EXPECTED" != "$ACTUAL" ]; then
      die "checksum mismatch for $ASSET (expected $EXPECTED, got $ACTUAL). Refusing to install."
    else
      log "Checksum verified."
    fi
  else
    log "NOTE: the release publishes no .sha256 for this asset; integrity rests on HTTPS/TLS only (Astrid is not code-signed yet). Homebrew gives a stronger guarantee if available."
  fi

  log "Extracting into $BIN_DIR..."
  mkdir -p "$BIN_DIR"
  tar -xzf "$TMP/$ASSET" -C "$TMP" || die "failed to extract $ASSET."

  # The tarball carries the binaries at its top level (the Homebrew formula
  # installs them by bare name). Place each one that's present.
  placed=0
  for b in astrid astrid-daemon astrid-build; do
    if [ -f "$TMP/$b" ]; then
      install -m 0755 "$TMP/$b" "$BIN_DIR/$b" 2>/dev/null || { cp "$TMP/$b" "$BIN_DIR/$b" && chmod 0755 "$BIN_DIR/$b"; }
      placed=$((placed + 1))
    fi
  done
  [ "$placed" -gt 0 ] || die "the downloaded archive contained none of the expected binaries (astrid/astrid-daemon/astrid-build)."

  [ -x "$BIN_DIR/astrid" ] || die "install completed but $BIN_DIR/astrid is missing or not executable."
  log "Installed $placed binar$( [ "$placed" -eq 1 ] && echo y || echo ies ) into $BIN_DIR."
  "$BIN_DIR/astrid" --version >&2 2>/dev/null || true

  # PATH guidance: the plugin finds ~/.astrid/bin/astrid regardless, but the
  # user's own shell won't until $BIN_DIR is on PATH.
  case ":${PATH}:" in
    *":$BIN_DIR:"*) : ;;
    *) log "Tip: add Astrid to your PATH — echo 'export PATH=\"$BIN_DIR:\$PATH\"' >> ~/.profile (the plugin already looks here, so this is only for your own shell)." ;;
  esac
  log "Done. Start a new Claude Code session (or run '$BIN_DIR/astrid start') to bring up the daemon."
  exit 0
fi

# --- 3. Source build (exotic platforms only) -------------------------------
log "No prebuilt Astrid binary is published for $OS/$ARCH."
if command -v cargo >/dev/null 2>&1; then
  log "cargo detected — attempting a source build (this is slow and needs a full toolchain)..."
  if cargo install --git "https://github.com/$REPO" astrid-cli astrid-daemon >&2; then
    if command -v astrid >/dev/null 2>&1; then
      log "Built and installed from source via cargo: $(command -v astrid)."
      astrid --version >&2 2>/dev/null || true
      exit 0
    fi
  fi
  log "The cargo source build did not produce a usable 'astrid'."
fi

die "could not install Astrid automatically on $OS/$ARCH. Build from source manually:
  git clone https://github.com/$REPO && cd astrid && cargo build --release
then put target/release/{astrid,astrid-daemon,astrid-build} on your PATH (or in $BIN_DIR).
See https://github.com/$REPO for details."

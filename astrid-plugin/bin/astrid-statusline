#!/usr/bin/env sh
# astrid-statusline — Claude Code status line rendered as an "Astrid HUD".
#
# Overlays the Astrid layer (principal + daemon state) onto the standard
# model / dir / git / context / cost line, so a glance tells you WHO you're
# acting as and WHETHER the runtime is live.
#
#   ⬡ astrid:<principal> ●  │ <model> │ <dir> ⎇ <branch> │ ▓▓▓░░ 42% │ $0.12
#                        ^ governance health: green ● = governed (daemon up
#                          AND sage-mcp broker loaded), yellow ◐ = daemon up
#                          but broker MISSING (gate fails open — ungoverned),
#                          dim ○ = daemon down (ungoverned). Cooperative
#                          plugin mode has no OS-sandbox floor under a dead
#                          gate, so the dot must not claim governance it
#                          can't back: socket-exists is not "gate answering".
#
# A plugin cannot register the MAIN status line — Claude Code only lets a
# plugin default `agent`/`subagentStatusLine`. The user wires this once in
# ~/.claude/settings.json:
#   "statusLine": { "type": "command",
#                   "command": "<plugin-root>/bin/astrid-statusline" }
# The /astrid:hud command prints the exact snippet (and path) to paste.
#
# CONTRACT: stdin = Claude Code's JSON status payload; stdout = ONE line.
# Must be FAST (re-runs on every refresh): the principal is a local
# context-file read, and the governance health is a CACHED daemon round-trip
# — most renders read a cache file with a short TTL, and at most one render
# per TTL pays the actual `astrid status` round-trip. (An honest gate signal
# needs the round-trip; the cache keeps it cheap.)
set -eu

input="$(cat 2>/dev/null || true)"

ASTRID="$(command -v astrid 2>/dev/null || true)"
[ -n "$ASTRID" ] || ASTRID="$HOME/.astrid/bin/astrid"
ASTRID_HOME_DIR="${ASTRID_HOME:-$HOME/.astrid}"
SOCK="$ASTRID_HOME_DIR/run/system.sock"

# ANSI colors via a real ESC byte, so report content (which never contains
# escapes) can be concatenated with plain parameter expansion.
ESC=$(printf '\033')
C_RESET="${ESC}[0m"; C_DIM="${ESC}[2m"; C_CY="${ESC}[36m"
C_GN="${ESC}[32m"; C_YE="${ESC}[33m"; C_GY="${ESC}[90m"

# Principal — local context-file read (fast; works even if daemon is down).
PRINCIPAL="default"
if [ -x "$ASTRID" ]; then
  p="$("$ASTRID" agent current 2>/dev/null | head -n1 | tr -d '[:space:]')"
  [ -n "$p" ] && PRINCIPAL="$p"
fi

# Governance health — does the gate PATH actually answer, not just "socket
# file present". A stale socket (dead daemon) or a live daemon with the
# sage-mcp broker unloaded both leave the PreToolUse gate failing open
# (ungoverned), yet a socket-exists test would show green. The real check is
# a daemon round-trip (`astrid status`: reachable iff it prints a PID line,
# broker live iff `sage-mcp` is in its capsule list). That is too slow per
# refresh, so it is cached with a short TTL — cache-hit most renders, one
# round-trip per TTL.
HEALTH_CACHE="$ASTRID_HOME_DIR/run/.hud-health"
HEALTH_TTL=15
NOW="$(date +%s 2>/dev/null || echo 0)"
GATE=""   # up | degraded | down

# Fresh cache hit? (format: "<epoch> <state>")
if [ -r "$HEALTH_CACHE" ]; then
  cached="$(cat "$HEALTH_CACHE" 2>/dev/null || true)"
  c_ts="${cached%% *}"; c_state="${cached#* }"
  if [ -n "$c_ts" ] && [ "$NOW" -gt 0 ] && [ "$c_ts" -eq "$c_ts" ] 2>/dev/null; then
    age=$(( NOW - c_ts ))
    [ "$age" -ge 0 ] && [ "$age" -lt "$HEALTH_TTL" ] && GATE="$c_state"
  fi
fi

# Stale/missing → probe once and refresh the cache. Gate the round-trip
# behind socket presence so a never-started daemon costs nothing, and bound
# `astrid status` with `timeout` when available (a stale socket must not hang
# the status line).
if [ -z "$GATE" ]; then
  if [ ! -S "$SOCK" ]; then
    GATE="down"
  elif [ -x "$ASTRID" ]; then
    st="$( { if command -v timeout >/dev/null 2>&1; then timeout 2 "$ASTRID" status; \
             else "$ASTRID" status; fi; } 2>/dev/null || true )"
    if ! printf '%s' "$st" | grep -q '(PID'; then
      GATE="down"
    elif printf '%s' "$st" | sed -n 's/^[[:space:]]*-[[:space:]]*//p' | grep -qiE 'sage-mcp'; then
      GATE="up"
    else
      GATE="degraded"
    fi
  else
    GATE="down"
  fi
  printf '%s %s\n' "$NOW" "$GATE" > "$HEALTH_CACHE" 2>/dev/null || true
fi

case "$GATE" in
  up)       DOT="${C_GN}●${C_RESET}" ;;
  degraded) DOT="${C_YE}◐${C_RESET}" ;;
  *)        DOT="${C_GY}○${C_RESET}" ;;
esac

# Claude-side fields, via jq when available.
MODEL=""; DIR=""; PCT=""; COST=""
if [ -n "$input" ] && command -v jq >/dev/null 2>&1; then
  MODEL="$(printf '%s' "$input" | jq -r '.model.display_name // .model.id // empty' 2>/dev/null || true)"
  DIR="$(printf '%s' "$input" | jq -r '.workspace.current_dir // .cwd // empty' 2>/dev/null || true)"
  PCT="$(printf '%s' "$input" | jq -r '.context_window.used_percentage // empty' 2>/dev/null | cut -d. -f1 || true)"
  COST="$(printf '%s' "$input" | jq -r '.cost.total_cost_usd // empty' 2>/dev/null || true)"
fi
[ -n "$DIR" ] || DIR="$PWD"
DIRBASE="$(basename "$DIR" 2>/dev/null || printf '%s' "$DIR")"
BRANCH="$(git -C "$DIR" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"

# Compose one line.
OUT="${C_CY}⬡ astrid:${PRINCIPAL}${C_RESET} ${DOT}"
[ -n "$MODEL" ] && OUT="${OUT} ${C_GY}│${C_RESET} ${C_DIM}${MODEL}${C_RESET}"
OUT="${OUT} ${C_GY}│${C_RESET} ${DIRBASE}"
[ -n "$BRANCH" ] && OUT="${OUT} ${C_DIM}⎇ ${BRANCH}${C_RESET}"
if [ -n "$PCT" ] && [ "$PCT" -eq "$PCT" ] 2>/dev/null; then
  bw=10; fill=$(( PCT * bw / 100 ))
  [ "$fill" -lt 0 ] && fill=0; [ "$fill" -gt "$bw" ] && fill="$bw"
  empty=$(( bw - fill )); bar=""
  n=0; while [ "$n" -lt "$fill" ];  do bar="${bar}▓"; n=$((n + 1)); done
  n=0; while [ "$n" -lt "$empty" ]; do bar="${bar}░"; n=$((n + 1)); done
  OUT="${OUT} ${C_GY}│${C_RESET} ${bar} ${PCT}%"
fi
[ -n "$COST" ] && OUT="${OUT} ${C_GY}│${C_RESET} ${C_YE}\$${COST}${C_RESET}"

printf '%s\n' "$OUT"
